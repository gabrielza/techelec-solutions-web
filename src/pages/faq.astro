---
import BaseLayout from "../layouts/BaseLayout.astro";
import CtaBanner from "../components/CtaBanner.astro";
import FaqList from "../components/FaqList.astro";
import { faqs } from "../data/faqs";

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a },
  })),
};
---
<BaseLayout title="FAQ" description="Common questions about solar, backup, warranties, pricing and CoC certificates — answered by Techelec Solutions.">
  <section class="bg-[color:var(--color-ink)] py-20 text-white">
    <div class="mx-auto max-w-7xl px-6">
      <span class="eyebrow !bg-white/10 !text-white">FAQ</span>
      <h1 class="mt-4 text-4xl font-bold sm:text-5xl">Frequently asked questions</h1>
      <p class="mt-4 max-w-2xl text-slate-300">Everything our customers ask before they sign off a job.</p>
    </div>
  </section>

  <section class="section">
    <FaqList />
  </section>

  <CtaBanner />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
</BaseLayout>
