---
import BaseLayout from "../layouts/BaseLayout.astro";
import CtaBanner from "../components/CtaBanner.astro";
import { site } from "../data/site";
---
<BaseLayout title="About" description="Techelec Solutions is a Cape Town based solar, backup and electrical specialist — Master Deye installers serving the Western Cape.">
  <section class="bg-[color:var(--color-ink)] py-20 text-white">
    <div class="mx-auto max-w-7xl px-6">
      <span class="eyebrow !bg-white/10 !text-white">About</span>
      <h1 class="mt-4 text-4xl font-bold sm:text-5xl">Cape Town's no-nonsense<br/>energy team</h1>
      <p class="mt-4 max-w-2xl text-slate-300">{site.tagline}</p>
    </div>
  </section>

  <section class="section">
    <div class="grid gap-12 lg:grid-cols-3">
      <div class="lg:col-span-2 space-y-6 text-slate-700 leading-relaxed">
        <p class="text-lg">
          {site.legalName} is a Kuilsriver-based electrical and solar installation company serving the Cape Town metro and surrounding Western Cape. We design and install grid-tied, hybrid and off-grid solar systems, battery backup solutions, and handle every kind of general electrical work along the way.
        </p>
        <p>
          Our mission is straightforward: <strong>sustainable energy at a price normal South Africans can afford.</strong> That means right-sizing systems instead of overselling, sourcing top-tier components at fair prices, and signing off every job with a Department of Labour Certificate of Compliance.
        </p>
        <p>
          As accredited Master Deye Installers and PV GreenCard professionals, we know hybrid inverters and lithium battery banks inside-out — and we back our workmanship with a clear warranty so you know exactly where you stand.
        </p>

        <div class="grid gap-4 pt-4 sm:grid-cols-3">
          <div class="rounded-2xl border border-slate-200 p-5">
            <p class="text-3xl font-bold text-[color:var(--color-brand-red)]">100%</p>
            <p class="mt-1 text-sm text-slate-600">Installations issued with a CoC</p>
          </div>
          <div class="rounded-2xl border border-slate-200 p-5">
            <p class="text-3xl font-bold text-[color:var(--color-brand-red)]">3 – 5%</p>
            <p class="mt-1 text-sm text-slate-600">Annual maintenance retainer fee</p>
          </div>
          <div class="rounded-2xl border border-slate-200 p-5">
            <p class="text-3xl font-bold text-[color:var(--color-brand-red)]">24/7</p>
            <p class="mt-1 text-sm text-slate-600">WhatsApp support after install</p>
          </div>
        </div>
      </div>

      <aside class="space-y-4">
        <div class="rounded-2xl border border-slate-200 bg-white p-6">
          <h3 class="font-semibold">Accreditations</h3>
          <ul class="mt-3 space-y-3 text-sm">
            {site.certifications.map((c) => (
              <li>
                <p class="font-semibold">{c.name}</p>
                <p class="text-slate-500">{c.note}</p>
              </li>
            ))}
          </ul>
        </div>
        <div class="rounded-2xl bg-[color:var(--color-mist)] p-6">
          <h3 class="font-semibold">Visit / Write</h3>
          <p class="mt-2 text-sm text-slate-600">
            {site.address.street}<br/>
            {site.address.suburb}, {site.address.city}<br/>
            {site.address.postal}
          </p>
          <p class="mt-3 text-sm text-slate-600">{site.hours}</p>
        </div>
      </aside>
    </div>
  </section>

  <CtaBanner />
</BaseLayout>
