---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout title="Page not found" noindex>
  <section class="section text-center">
    <p class="text-7xl font-bold text-[color:var(--color-brand-red)]">404</p>
    <h1 class="mt-4 text-3xl font-bold">We can't find that page</h1>
    <p class="mt-3 text-slate-600">It may have moved or never existed. Try the homepage or contact us.</p>
    <div class="mt-8 flex flex-wrap justify-center gap-3">
      <a href="/" class="btn-primary">Go home</a>
      <a href="/contact/" class="btn-secondary">Contact us</a>
    </div>
  </section>
</BaseLayout>
