---
import type { Service } from "../data/services";

interface Props { service: Service }
const { service } = Astro.props;

const icons: Record<Service["icon"], string> = {
  solar:
    '<circle cx="12" cy="12" r="4"/><line x1="12" y1="2" x2="12" y2="5"/><line x1="12" y1="19" x2="12" y2="22"/><line x1="2" y1="12" x2="5" y2="12"/><line x1="19" y1="12" x2="22" y2="12"/><line x1="4.6" y1="4.6" x2="6.7" y2="6.7"/><line x1="17.3" y1="17.3" x2="19.4" y2="19.4"/><line x1="4.6" y1="19.4" x2="6.7" y2="17.3"/><line x1="17.3" y1="6.7" x2="19.4" y2="4.6"/>',
  battery:
    '<rect x="3" y="7" width="16" height="10" rx="2"/><line x1="21" y1="10" x2="21" y2="14"/><line x1="7" y1="10" x2="7" y2="14"/><line x1="11" y1="10" x2="11" y2="14"/><line x1="15" y1="10" x2="15" y2="14"/>',
  compliance:
    '<path d="M12 2 4 5v6c0 5 3.5 9.3 8 11 4.5-1.7 8-6 8-11V5l-8-3Z"/><polyline points="9 12 11.5 14.5 16 10"/>',
  maintenance:
    '<path d="M14.7 6.3a4 4 0 1 0 5 5l-4-4 3-3a6 6 0 0 0-8 8L4 19l1 1 7-7Z"/>',
  industrial:
    '<path d="M3 21V11l5 3V11l5 3V11l5 3v7Z"/><line x1="3" y1="21" x2="21" y2="21"/>',
  agri:
    '<path d="M12 22V8"/><path d="M5 8c0-3 3-5 7-5s7 2 7 5c0 3-3 5-7 5s-7-2-7-5Z"/><path d="M2 16c2-1 5-1 7 1 2-2 5-2 7-1"/>',
};
---
<a href={`/services/#${service.slug}`} class="group relative flex flex-col rounded-2xl border border-slate-200 bg-white p-7 transition-all duration-200 hover:-translate-y-1 hover:border-[color:var(--color-brand-blue)]/40 hover:shadow-xl">
  <div class="mb-4 inline-flex h-12 w-12 items-center justify-center rounded-xl bg-[color:var(--color-brand-red)]/10 text-[color:var(--color-brand-red)] group-hover:bg-[color:var(--color-brand-red)] group-hover:text-white transition-colors">
    <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={icons[service.icon]} />
  </div>
  <h3 class="text-lg font-semibold">{service.title}</h3>
  <p class="mt-1 text-sm text-[color:var(--color-brand-blue-dark)] font-medium">{service.short}</p>
  <p class="mt-3 text-sm text-slate-600 line-clamp-3">{service.blurb}</p>
  <span class="mt-5 inline-flex items-center gap-1 text-sm font-semibold text-[color:var(--color-brand-red)]">
    Learn more
    <svg class="h-4 w-4 transition-transform group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
  </span>
</a>
