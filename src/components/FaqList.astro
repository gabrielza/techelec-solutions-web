---
import { faqs } from "../data/faqs";

interface Props { limit?: number }
const { limit } = Astro.props;
const items = limit ? faqs.slice(0, limit) : faqs;
---
<div class="mx-auto max-w-3xl divide-y divide-slate-200">
  {items.map((f, i) => (
    <details class="group py-5" open={i === 0}>
      <summary class="flex cursor-pointer list-none items-start justify-between gap-6 text-left">
        <span class="text-base font-semibold text-[color:var(--color-ink)] sm:text-lg">{f.q}</span>
        <span class="mt-1 flex h-7 w-7 flex-none items-center justify-center rounded-full bg-slate-100 text-[color:var(--color-brand-red)] transition-transform group-open:rotate-45">
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        </span>
      </summary>
      <p class="mt-3 text-slate-600 leading-relaxed">{f.a}</p>
    </details>
  ))}
</div>
